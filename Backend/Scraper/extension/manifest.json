{
  "manifest_version": 3,
  "name": "AutoFill Form Scraper",
  "version": "0.1.0",
  "description": "Scrapes visible form fields and sends requirements to backend.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AutoFill",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
